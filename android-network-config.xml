<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext (HTTP) traffic to AWS backend -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">18.207.238.14</domain>
    </domain-config>

    <!-- For development/beta: Allow all cleartext traffic -->
    <!-- TODO: Remove this in production when backend has HTTPS -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
